# ──────────────────────────────────────────────────────────────────────────
# Setup cepat: cukup isi TOKEN di bawah, jalankan bot, lalu ketik  !setup
# di server Discord untuk mengatur SEMUA channel/role lewat dropdown (tanpa
# menyalin ID manual). Nilai dari wizard disimpan di database & menimpa file ini.
# Prioritas nilai: Setup Wizard (/setup) > .env > default bawaan.
# Mengisi variabel di bawah tetap didukung bila kamu lebih suka cara manual.
# ──────────────────────────────────────────────────────────────────────────
TOKEN=
GUILD_ID=
STORE_NAME=
ADMIN_ROLE_ID=
TICKET_CATEGORY_ID=
LOG_CHANNEL_ID=
TRANSCRIPT_CHANNEL_ID=
BACKUP_CHANNEL_ID=
ERROR_LOG_CHANNEL_ID=
VILOG_CHANNEL_ID=
VILOG_CATALOG_CHANNEL_ID=1493576431718895677
MIDMAN_CHANNEL_ID=
ROBUX_CATALOG_CHANNEL_ID=
ML_CATALOG_CHANNEL_ID=
LAINNYA_AUTOREPLY_CHANNEL_ID=1508564472141447389
SELFROLES_CHANNEL_ID=
DANA_NUMBER=
BCA_NUMBER=
TESTIMONI_CHANNEL_ID=
REVIEWER_BADGE_ROLE_ID=
REVIEWER_BADGE_THRESHOLD=3
WARRANTY_CHANNEL_ID=
DAILY_REPORT_CHANNEL_ID=1476351037412610048
CELLYN_TEAM_ROLE_ID=
# Kunci enkripsi kredensial Vilog (email/password/kode backup akun Roblox
# customer) yang disimpan di database. OPSIONAL: bila dikosongkan, kunci
# diturunkan otomatis dari TOKEN. Isi dengan string acak panjang & rahasia bila
# ingin kunci terpisah dari TOKEN (mis. agar rotasi token tidak melumpuhkan
# dekripsi). JANGAN bagikan / commit nilai ini.
VILOG_SECRET_KEY=
RELAY_SOURCE_CHANNEL_ID=
RELAY_WEBHOOK_URL=
RELAY_INCLUDE_BOT=1
RELAY_ALLOW_MENTIONS=0
